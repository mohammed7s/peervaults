BASE_RPC_URL=https://mainnet.base.org
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
RUNTIME_ENV=production

# Set this to your dad's wallet if he should manage the vault day to day.
MANAGER_ADDRESS=

# Optional. Defaults to MANAGER_ADDRESS when omitted.
FEE_RECIPIENT=

VAULT_NAME=My First Peer Vault
VAULT_URI=https://example.com/vaults/my-first-peer-vault.json

# Human percentages, not 1e18 wad values.
FEE_PERCENT=0.10
MAX_FEE_PERCENT=2.00

# Human USDC amount. 0 disables the minimum.
MIN_LIQUIDITY_USDC=0

# Frontend app config. Only VITE_ variables are exposed to the browser.
VITE_APP_NAME=PeerVaults
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_PEER_RUNTIME_ENV=production
VITE_PEER_RATE_MANAGER_ADDRESS=0xeEd7Db23e724aC4590D6dB6F78fDa6DB203535F3

# Optional fallback if you want to force one vault instead of auto-discovering
# vaults for the connected manager wallet.
VITE_PEER_VAULT_ID=
